# ══════════════════════════════════════════════════
# LaMa Yatayat Backend - Environment Configuration
# Copy this to .env and fill in your values
# ══════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=debug

# ─── Database (PostgreSQL) ───────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=lamayatayat
DB_PASSWORD=devpassword123
DB_NAME=lamayatayat
DB_SSL_MODE=disable
DB_MAX_CONNECTIONS=25
DB_URL=postgres://lamayatayat:devpassword123@localhost:5432/lamayatayat?sslmode=disable

# ─── Redis ───────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ─── JWT Auth ────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=720h

# ─── Service Ports ───────────────────────────────
USER_SERVICE_PORT=8001
RIDE_SERVICE_PORT=8002
ROUTE_MATCHING_PORT=8003
GEOLOCATION_SERVICE_PORT=8004
PAYMENT_SERVICE_PORT=8005
PRICING_SERVICE_PORT=8006
NOTIFICATION_SERVICE_PORT=8007
CONNECTION_SERVICE_PORT=8008

# ─── Stripe (Test Mode) ─────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# ─── Google Maps ─────────────────────────────────
GOOGLE_MAPS_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Expo Push Notifications ────────────────────
EXPO_ACCESS_TOKEN=

# ─── Pricing Config ─────────────────────────────
BASE_FARE_ROUND_TRIP=20.00
BASE_FARE_ONE_WAY=10.00
PLATFORM_COMMISSION_PERCENT=8

# ─── Route Matching ─────────────────────────────
MATCHING_CORRIDOR_METERS=1000
MATCHING_MAX_DETOUR_PERCENT=20
MATCHING_MIN_BATCH_SIZE=1
MATCHING_MAX_BATCH_SIZE=4
MATCHING_ROUTE_EXTENSION_PERCENT=15
